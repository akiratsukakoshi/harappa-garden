# garden-gaku-co — 環境変数テンプレート
# 実体の .env は VPS 上にのみ置く(chmod 600)。値は chat / git に出さない。

# --- Discord ---
# Discord Developer Portal で発行する bot token(秘密。VPS の .env に直接記入)
DISCORD_BOT_TOKEN=
# 塚越さん ↔ 秘書の master channel ID(開発者モード → チャンネル右クリック → ID コピー)
DISCORD_MASTER_CHANNEL_ID=

# --- Garden 共有 substrate(ホストパス。段1-2 はホストスクリプトで動く)---
# garden-mirror のホスト上の場所(active_tasks / archive / board を読む)
MIRROR_DIR=/home/vps-harappa/garden-mirror

# --- 頭脳(claude -p / Claude Code ヘッドレス、サブスク認証)---
# VPS の claude バイナリのフルパス(launcher と同じ。cron は .bashrc 非読込なのでフルパス必須)
CLAUDE_BIN=/home/vps-harappa/.npm-global/bin/claude

# --- 社内 LINE(core_team / 運営スタッフ)Webhook サーバ ---
# ADR 2026-06-03 vendor-neutral §決定5:社外(gaku-co5.0)とは別建て(別 LINE 公式 + 別 API key)。
# 実値は VPS の .env にガクチョが直接記入(chat / git には出さない)。
# LINE Developers Console(社内用プロバイダー)で取得した secret / token。
LINE_CORE_TEAM_CHANNEL_SECRET=
LINE_CORE_TEAM_ACCESS_TOKEN=
# bot を追加した運営スタッフ LINE グループの groupId(疎通後に webhook ログから確定して記入)。
# このサーバはこの group ID のメッセージ「だけ」を処理する(エアギャップ)。
LINE_CORE_TEAM_GROUP_ID=
# Stage1 ゲート / Stage2 応答の頭脳 b(Anthropic SDK・Haiku)用 API key。社外と別建て。
ANTHROPIC_API_KEY=
# uvicorn bind(NPM 社内サブドメインから proxy する。既定 127.0.0.1:8011)
LINE_SERVER_HOST=127.0.0.1
LINE_SERVER_PORT=8011
