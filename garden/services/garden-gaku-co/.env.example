# garden-gaku-co — 環境変数テンプレート
# 実体の .env は VPS 上にのみ置く(chmod 600)。値は chat / git に出さない。

# --- Discord ---
# Discord Developer Portal で発行する bot token(秘密。VPS の .env に直接記入)
DISCORD_BOT_TOKEN=
# 塚越さん ↔ 秘書の master channel ID(開発者モード → チャンネル右クリック → ID コピー)
DISCORD_MASTER_CHANNEL_ID=

# --- Garden 共有 substrate(ホストパス。段1-2 はホストスクリプトで動く)---
# garden-mirror のホスト上の場所(active_tasks / archive / board を読む)
MIRROR_DIR=/home/vps-harappa/garden-mirror

# --- 頭脳(claude -p / Claude Code ヘッドレス、サブスク認証)---
# VPS の claude バイナリのフルパス(launcher と同じ。cron は .bashrc 非読込なのでフルパス必須)
CLAUDE_BIN=/home/vps-harappa/.npm-global/bin/claude
