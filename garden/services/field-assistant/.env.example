# field_assistant — VPS では実値を .env に(600 perm、git 管理しない)
# STORES 予約 API(参照系のみ)。ローカル /home/tukapontas/storesyoyaku/.env と同じ値
STORES_API_TOKEN=
# LINE push 先: core_team グループ ID(投入前はガクチョの userId で 1:1 テスト)
# カンマ区切りで複数可
FIELD_LINE_TO=
# LINE チャネルトークン(garden-gaku-co/.env と同じ値を共有)
LINE_CORE_TEAM_ACCESS_TOKEN=
# 名簿出力ワークブック(⭐ガクチョ作成 → SA に Editor 共有 → ID 記入)
FIELD_ROSTER_SHEET_ID=
# 以下は既定で shift-manager の SA / config を流用(変える時だけ設定)
# GOOGLE_SA_FILE=/home/vps-harappa/garden/services/shift-manager/secrets/credentials.json
# SHIFT_CALENDAR_SHEET_ID=
