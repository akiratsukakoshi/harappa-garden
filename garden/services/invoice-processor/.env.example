# invoice-processor 環境変数(VPS では実値を .env に。secret は chmod 600)

# --- Freee(他 Garden service と OAuth client / token 物理ファイルを共有)---
FREEE_CLIENT_ID=
FREEE_CLIENT_SECRET=
FREEE_TARGET_COMPANY_ID=
# shift-manager / expense-processor と同じファイルを指す(refresh ローテ対策で物理共有)
FREEE_TOKEN_FILE=/home/vps-harappa/garden/services/shift-manager/secrets/freee_tokens.json

# --- Gemini(PDF 解析)---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Google Drive フォルダ(HMC Invoices/{Inbox,Processed,Error} を継承)---
DRIVE_INBOX_ID=
DRIVE_PROCESSED_ID=
DRIVE_ERROR_ID=

# --- レビュー用 Sheets(ガクチョ所有ワークブック。user OAuth で読むので共有不要)---
INVOICE_REVIEW_SHEET_ID=

# --- 稼働突合 ---
# 稼働時間ワークブック(省略時は ../shift-manager/config/config_ids.json の working_hours_id)
# WORKING_HOURS_SHEET_ID=
# soil スタッフマスター(VPS は garden-mirror 配下を明示。ローカルは相対既定で OK)
SOIL_STAFF_DIR=/home/vps-harappa/garden-mirror/garden/soil/people/staff

# --- user OAuth token(既定: secrets/user_token.json。issue_token.py で発行)---
# INVOICE_USER_TOKEN=
# INVOICE_OAUTH_CREDENTIALS=
