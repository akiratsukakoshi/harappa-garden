# garden-writeback-daemon env (VPS のみ配置、git 管理外)
# 配置先: ~/garden/services/writeback-daemon/.env (chmod 600)
#
# COUCHDB credentials は garden-couchdb と同じ値を使う
# E2EE_PASSPHRASE は LiveSync 側と完全一致(mirror-daemon と同じ値)

COUCHDB_URL=http://garden-couchdb:5984
COUCHDB_USER=garden-admin
COUCHDB_PASS=__SAME_AS_GARDEN_COUCHDB__
DATABASE=gakuchovault
E2EE_PASSPHRASE=__LIVESYNC_E2EE_PASSPHRASE__

# Mirror source on host(mirror-daemon と同じディレクトリを読み専用でマウント)
MIRROR_HOST_PATH=/home/vps-harappa/garden-mirror

# 連続書き込みのファイナル待ち(ms)
DEBOUNCE_MS=1500
