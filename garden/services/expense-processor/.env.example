# expense-processor service .env(VPS の service ルートに .env として配置、600 perm)
# 値はガクチョのコンソール操作で記入する。git には載せない(.gitignore)。

# --- Freee OAuth ---
FREEE_CLIENT_ID=
FREEE_CLIENT_SECRET=
FREEE_TARGET_COMPANY_ID=
# Freee の OAuth トークンは secrets/freee_tokens.json に置く(access/refresh token の JSON)。
# 既存 HMC の modules/freee_tokens.json をコピーして流用可。

# --- Gemini(レシート OCR + 費目分類)---
GEMINI_API_KEY=

# --- Google Drive(input フォルダ同期・アーカイブ)---
# Drive の経費フォルダ ID。配下に input/ を作って明細・レシートを置く。
EXPENSE_DRIVE_FOLDER_ID=
# Drive 認証は secrets/credentials.json(OAuth クライアント or サービスアカウント)
# + secrets/token.json(OAuth トークン pickle)に置く。

# --- ⭐ 消費税区分(課税仕入)---
# 経費は本来「課税仕入」。未設定だと Freee 既定の tax_code=1(課税売上 10%)で
# 登録され会計上の誤りになる。`python processor.py taxes` で実コードを確認し、
# 「課対仕入 10%」のコードを設定すること。
EXPENSE_TAX_CODE=
