# sns-manager secret テンプレ(VPS 上 ~/.../sns-manager/.env に実値。repo に実値を置かない)

# --- Meta Graph API(HMC .env から流用)---
META_ACCESS_TOKEN=
META_IG_ACCOUNT_ID=
META_PAGE_ID=

# --- ig_scheduler(VPS 稼働コンテナを共用。HMC .env から流用)---
IG_SCHEDULER_API_URL=https://ig-api.harappa.monster
IG_SCHEDULER_API_KEY=

# --- Google(候補画像 DL + KPI Sheets。expense/invoice と同じ SA を流用)---
# GOOGLE_SA_FILE 未設定なら secrets/service_account.json を使う
GOOGLE_SA_FILE=
SNS_DRIVE_FOLDER_ID=
SNS_SHEET_ID=
