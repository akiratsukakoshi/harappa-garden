# System
.DS_Store

# Claude Code local settings (個人的な許可リスト等、git に上げない)
.claude/

# Codex local settings (同上)
.codex/

# WSL / Windows download metadata
*:Zone.Identifier

# Python
venv/
.venv/
__pycache__/
*.pyc

# Project Data
data/
.env
.env.*
*.swp
.*.swp
modules/freee_tokens.json
credentials.json
token.json
oauth_credentials.json

# Sheet extracts and other private data caches
**/_data/

# Logs
run_log.txt
*.log
*.csv

# Secrets
docs/security/secrets/*
!docs/security/secrets/.gitkeep

# Garden service の secret / 中間データ(VPS のみ。repo に入れない)
garden/services/*/secrets/
garden/services/*/working/
garden/services/*/temp/
garden/services/*/input/
garden/services/*/proceeded/

# VPS リソース管理(secret / backup)
vps/proxy-manager/backups/*.tar.gz
vps/proxy-manager/data/
vps/proxy-manager/letsencrypt/
vps/ig_scheduler/.env
vps/**/*.db

# Memory RAW(対話の生ログ、機密扱い。S22 Stage A 以降)
# ADR: docs/decisions/2026-05-31-memory-three-layer-and-soil-routing.md
garden/memory/**/raw/*.md
!garden/memory/**/raw/.gitkeep

# field-assistant (S42): 名簿/振替の出力 CSV は PII を含むため repo に載せない
garden/services/field-assistant/output/

# scribe (S54): ローカル実行のランタイム。repo に載せない。
#   state = べき等 watermark / outbox = board を VPS へ push するまでの一時置き場(push 後は空)。
#   ★board の住所は VPS /home/vps-harappa/garden/board/pending/ 一箇所。repo に board の
#     コンテンツ用ディレクトリは持たない(S57: 旧 board/pending ローカル溜まりの混乱を撤去)。
garden/services/scribe/state/
garden/services/meeting-coordinator/state/*.json
garden/services/meeting-coordinator/state/*.tmp
garden/services/meeting-coordinator/__pycache__/
garden/services/scribe/outbox/
